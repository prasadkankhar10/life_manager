# Application
APP_ENV=development
HOST=127.0.0.1
PORT=8000
BASE_URL=
TIMEZONE=Asia/Kolkata
DATABASE_PATH=storage/life_manager.db
DAILY_SUMMARY_TIME=08:00

# Telegram — create a bot with @BotFather
TELEGRAM_BOT_TOKEN=
# Your numeric Telegram user ID. The bot ignores every other user.
TELEGRAM_ALLOWED_USER_ID=
# Use polling when the app runs locally; use webhook only after public HTTPS deployment.
TELEGRAM_MODE=polling
# Generate a long random value. Required when using a webhook in production.
TELEGRAM_WEBHOOK_SECRET=

# Notion — create an internal integration, then share your Life Manager page with it.
NOTION_TOKEN=
NOTION_PARENT_PAGE_ID=
# These five values are written by: python -m scripts.setup_notion
NOTION_TASKS_DATA_SOURCE_ID=
NOTION_EXPENSES_DATA_SOURCE_ID=
NOTION_NOTES_DATA_SOURCE_ID=
NOTION_JOURNAL_DATA_SOURCE_ID=
NOTION_GOALS_DATA_SOURCE_ID=

# AI parsing is optional. With no key, slash commands and simple captures still work.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_ENABLED=true

# Leave blank only while running locally. Set a strong password before exposing the dashboard.
DASHBOARD_PASSWORD=
